# Minecraft server connection (server-level config, shared by all bots)
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.21.11

# Which bot from bots.json to run
BOT_NAME=AFK_Bot

# HTTP control API
API_PORT=3000
# API_TOKEN=          # if set, requests need: Authorization: Bearer <token>
STATE_FILE=./data/state.json
AUTO_START_BOT=false  # true = connect immediately when no saved state exists
